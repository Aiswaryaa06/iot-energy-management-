# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Local SQLite database file path
DB_FILE=../database/smarthome.db

# Azure SQL Database Configuration (Set this to switch from local SQLite to Azure SQL)
# AZURE_SQL_SERVER=your-server.database.windows.net
# AZURE_SQL_DATABASE=smarthomedb
# AZURE_SQL_USER=your-username
# AZURE_SQL_PASSWORD=your-password

# Azure IoT Hub Connection String (Used for physical/simulated device connection at scale)
# AZURE_IOT_HUB_CONNECTION_STRING=HostName=your-iot-hub.azure-devices.net;SharedAccessKeyName=iothubowner;SharedAccessKey=your-key

# Azure Monitor (Application Insights Instrumentation Key)
# APPINSIGHTS_INSTRUMENTATIONKEY=your-instrumentation-key

# Default Electricity Tariff (Currency units per kWh, e.g. 8.0 for ₹8)
DEFAULT_TARIFF=8.0
